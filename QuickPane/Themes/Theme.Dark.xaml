<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark theme. AccentBrush, ItemHoverBackground and ItemActiveBackground are replaced
         at runtime by ThemeService using the live Windows accent color. -->

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/QuickPane;component/Themes/Controls.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <SolidColorBrush x:Key="SidebarBackground" Color="#E61E1E1E" />
    <SolidColorBrush x:Key="TextPrimary"       Color="#FFEDEDED" />
    <SolidColorBrush x:Key="TextSecondary"     Color="#FF9B9B9B" />
    <SolidColorBrush x:Key="SeparatorColor"    Color="#FF3A3A3A" />
    <SolidColorBrush x:Key="ChevronColor"      Color="#FF8A8A8A" />
    <SolidColorBrush x:Key="DriveBarTrack"     Color="#FF3A3A3A" />
    <SolidColorBrush x:Key="BrokenLinkColor"   Color="#FFD06C6C" />

    <SolidColorBrush x:Key="AccentBrush"          Color="#FF0078D4" />
    <SolidColorBrush x:Key="ItemHoverBackground"  Color="#260078D4" />
    <SolidColorBrush x:Key="ItemActiveBackground" Color="#330078D4" />

</ResourceDictionary>
