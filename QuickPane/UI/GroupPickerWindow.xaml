<Window x:Class="QuickPane.UI.GroupPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" SizeToContent="Height" Width="300" Topmost="True"
        ResizeMode="NoResize">
    <Border x:Name="Shell" CornerRadius="8" BorderThickness="1" Padding="14">
        <StackPanel>
            <TextBlock x:Name="TitleText" Text="Pin to Quick Pane" FontSize="14" FontWeight="SemiBold" />
            <TextBlock x:Name="PathText" FontSize="11" Margin="0,2,0,10" TextTrimming="CharacterEllipsis" Opacity="0.7" />

            <ScrollViewer MaxHeight="260" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="GroupList" />
            </ScrollViewer>

            <TextBox x:Name="NewGroupBox" Margin="0,6,0,0" Visibility="Collapsed"
                     Text="" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button x:Name="CancelBtn" Content="Cancel" Width="74" Margin="0,0,8,0" Click="OnCancel" />
                <Button x:Name="OkBtn" Content="Pin" Width="74" Click="OnConfirm" IsDefault="True" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
