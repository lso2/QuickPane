<UserControl x:Class="QuickPane.UI.SidebarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="False" UseLayoutRounding="True" SnapsToDevicePixels="True">
    <Grid>
        <Border Background="{DynamicResource SidebarBackground}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Title header -->
                <StackPanel Grid.Row="0" x:Name="HeaderPanel">
                    <Grid Margin="10,8,6,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" x:Name="TitleContent" Orientation="Horizontal">
                            <Image Source="/QuickPane;component/quickpane.ico" Width="16" Height="16"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="QuickPane" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                        </StackPanel>
                        <Button Grid.Column="1" x:Name="TitleToggleButton" Width="22" Height="22"
                                Background="Transparent" BorderThickness="0" Cursor="Hand" Opacity="0.6"
                                ToolTip="Collapse" Click="OnTitleToggle">
                            <TextBlock x:Name="TitleToggleGlyph" Text="&#xE76B;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="11" Foreground="{DynamicResource TextSecondary}" />
                        </Button>
                    </Grid>
                    <Border Height="1" Background="{DynamicResource SeparatorColor}" Margin="8,0,8,0" />

                    <!-- Profile tabs row (auto-hide optional) -->
                    <ScrollViewer x:Name="ProfileTabsHost" HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled" Visibility="Collapsed" Tag="tabscroll">
                        <StackPanel x:Name="ProfileTabsBar" Orientation="Horizontal" Margin="6,3,6,3" />
                    </ScrollViewer>
                </StackPanel>

                <ScrollViewer Grid.Row="1" x:Name="Scroller" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled" Padding="0,6,0,44"
                              PreviewMouseWheel="OnScrollWheel">
                    <StackPanel x:Name="SectionsPanel" />
                </ScrollViewer>

                <!-- Buy me a coffee, bottom-left -->
                <Button Grid.Row="1" x:Name="SupportButton" Height="28" Opacity="0.6"
                        HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="8,0,0,8"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        ToolTip="Buy me a coffee" Click="OnSupportClick">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x2764;" FontSize="12" Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center" Margin="0,0,5,0" />
                        <TextBlock Text="Buy me a coffee" FontSize="11"
                                   Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
                    </StackPanel>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="4,2">
                                            <ContentPresenter VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="1" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Settings gear, bottom-right -->
                <Button Grid.Row="1" x:Name="GearButton" Width="28" Height="28" Opacity="0.4"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,22,8"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        ToolTip="Settings" Click="OnGearClick">
                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                               Foreground="{DynamicResource TextSecondary}" />
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="1" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Resize grip, drag to set sidebar width -->
                <Thumb Grid.Row="0" Grid.RowSpan="2" x:Name="ResizeThumb" Width="6"
                       HorizontalAlignment="Right" Cursor="SizeWE"
                       DragStarted="OnResizeStarted" DragDelta="OnResizeDelta" DragCompleted="OnResizeCompleted">
                    <Thumb.Template>
                        <ControlTemplate TargetType="Thumb">
                            <Border Background="Transparent" />
                        </ControlTemplate>
                    </Thumb.Template>
                </Thumb>
            </Grid>
        </Border>
    </Grid>
</UserControl>
